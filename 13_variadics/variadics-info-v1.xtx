━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
📌 12. VARIADIC vs SLICE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

| Feature     | Variadic | Slice     |
| ----------- | -------- | --------- |
| Syntax      | `...int` | `[]int`   |
| Input       | Multiple | One slice |
| Internal    | Slice    | Slice     |
| Flexibility | High     | Medium    |

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
📌 13. WHEN TO USE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

✅ Use When:
• Unknown number of inputs
• Cleaner APIs
• Logging / utilities

❌ Avoid When:
• Large datasets
• Performance critical

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
📌 14. SUMMARY
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
✔ Uses `...`
✔ Accepts multiple inputs
✔ Internally slice
✔ Must be last param
✔ Flexible & clean

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
📌 15. PRACTICE QUESTIONS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

1. Find max using variadic
2. Concatenate strings
3. Logger with timestamp
4. Average calculator

🔹 Example:

```go
func max(nums ...int) int {
    maxVal := nums[0]
    for _, n := range nums {
        if n > maxVal {
            maxVal = n
        }
    }
    return maxVal
}
```

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━