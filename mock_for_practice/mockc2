--------------------------------------------------------------------------------
A01. Reverse a String
--------------------------------------------------------------------------------
PROBLEM:
  Given a string, return it reversed.

APPROACH:
  Convert to rune slice (handles multi-byte UTF-8), swap from both ends.

CODE:
  package main

  import "fmt"

  func reverseString(s string) string {
      runes := []rune(s)
      left, right := 0, len(runes)-1
      for left < right {
          runes[left], runes[right] = runes[right], runes[left]
          left++
          right--
      }
      return string(runes)
  }

  func main() {
      fmt.Println(reverseString("hello"))   // olleh
      fmt.Println(reverseString("golang"))  // gnalog
      fmt.Println(reverseString("日本語"))   // 語本日 (UTF-8 safe)
  }

COMPLEXITY:
  Time:  O(n)
  Space: O(n) — rune slice copy

NOTE:
  Using []byte instead of []rune would break multi-byte characters.
  Always use []rune for Unicode safety in Go.

--------------------------------------------------------------------------------
A02. Check if String is a Palindrome
--------------------------------------------------------------------------------
PROBLEM:
  Return true if the string reads the same forwards and backwards.
  Ignore case and non-alphanumeric characters.

APPROACH:
  Two pointers. Skip non-alphanumeric, compare lowercased characters.

CODE:
  package main

  import (
      "fmt"
      "unicode"
  )

  func isPalindrome(s string) bool {
      runes := []rune(s)
      left, right := 0, len(runes)-1

      for left < right {
          for left < right && !unicode.IsLetter(runes[left]) &&
              !unicode.IsDigit(runes[left]) {
              left++
          }
          for left < right && !unicode.IsLetter(runes[right]) &&
              !unicode.IsDigit(runes[right]) {
              right--
          }
          if unicode.ToLower(runes[left]) != unicode.ToLower(runes[right]) {
              return false
          }
          left++
          right--
      }
      return true
  }

  func main() {
      fmt.Println(isPalindrome("A man, a plan, a canal: Panama")) // true
      fmt.Println(isPalindrome("race a car"))                     // false
      fmt.Println(isPalindrome(""))                               // true
  }

COMPLEXITY:
  Time:  O(n)
  Space: O(n) — rune conversion

