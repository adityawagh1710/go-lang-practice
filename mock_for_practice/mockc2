A06. Merge Two Sorted Slices
--------------------------------------------------------------------------------
PROBLEM:
  Given two sorted slices, return a single merged sorted slice.

APPROACH:
  Two pointers — pick the smaller element at each step.

CODE:
  package main

  import "fmt"

  func mergeSorted(a, b []int) []int {
      result := make([]int, 0, len(a)+len(b))
      i, j := 0, 0

      for i < len(a) && j < len(b) {
          if a[i] <= b[j] {
              result = append(result, a[i])
              i++
          } else {
              result = append(result, b[j])
              j++
          }
      }
      result = append(result, a[i:]...)
      result = append(result, b[j:]...)
      return result
  }

  func main() {
      fmt.Println(mergeSorted([]int{1, 3, 5}, []int{2, 4, 6}))
      // [1 2 3 4 5 6]
      fmt.Println(mergeSorted([]int{1, 2, 3}, []int{}))
      // [1 2 3]
  }

COMPLEXITY:
  Time:  O(n + m)
  Space: O(n + m) — result slice

