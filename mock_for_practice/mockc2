D04. Merge Channels
--------------------------------------------------------------------------------
PROBLEM:
  Write a function that takes multiple input channels and merges them
  into a single output channel. Close output when all inputs are done.

CODE:
  package main

  import (
      "fmt"
      "sync"
  )

  func mergeChannels(channels ...<-chan int) <-chan int {
      out := make(chan int)
      var wg sync.WaitGroup

      forward := func(ch <-chan int) {
          defer wg.Done()
          for v := range ch {
              out <- v
          }
      }

      wg.Add(len(channels))
      for _, ch := range channels {
          go forward(ch)
      }

      go func() {
          wg.Wait()
          close(out)
      }()
      return out
  }

  func sourceChannel(vals ...int) <-chan int {
      ch := make(chan int)
      go func() {
          for _, v := range vals {
              ch <- v
          }
          close(ch)
      }()
      return ch
  }

  func main() {
      ch1 := sourceChannel(1, 2, 3)
      ch2 := sourceChannel(10, 20)
      ch3 := sourceChannel(100)

      for v := range mergeChannels(ch1, ch2, ch3) {
          fmt.Print(v, " ")
      }
      fmt.Println()
      // Output: values from all 3 channels (order non-deterministic)
  }

