D01. FizzBuzz with Goroutines
--------------------------------------------------------------------------------
PROBLEM:
  Print FizzBuzz 1..n using 4 goroutines:
    - One prints "Fizz" (multiples of 3)
    - One prints "Buzz" (multiples of 5)
    - One prints "FizzBuzz" (multiples of 15)
    - One prints the number (neither)

APPROACH:
  Use 4 channels to signal which goroutine should print. A coordinator
  goroutine decides and sends to the correct channel.

CODE:
  package main

  import (
      "fmt"
      "sync"
  )

  func fizzBuzz(n int) {
      fizz     := make(chan struct{})
      buzz     := make(chan struct{})
      fizzbuzz := make(chan struct{})
      number   := make(chan int)
      done     := make(chan struct{})

      var wg sync.WaitGroup
      wg.Add(4)

      // Fizz goroutine
      go func() {
          defer wg.Done()
          for range fizz { fmt.Print("Fizz ") }
      }()

      // Buzz goroutine
      go func() {
          defer wg.Done()
          for range buzz { fmt.Print("Buzz ") }
      }()

      // FizzBuzz goroutine
      go func() {
          defer wg.Done()
          for range fizzbuzz { fmt.Print("FizzBuzz ") }
      }()

      // Number goroutine
      go func() {
          defer wg.Done()
          for n := range number { fmt.Print(n, " ") }
      }()

      // Coordinator
      go func() {
          for i := 1; i <= n; i++ {
              switch {
              case i%15 == 0: fizzbuzz <- struct{}{}
              case i%3  == 0: fizz     <- struct{}{}
              case i%5  == 0: buzz     <- struct{}{}
              default:        number   <- i
              }
          }
          close(fizz)
          close(buzz)
          close(fizzbuzz)
          close(number)
          done <- struct{}{}
      }()

      <-done
      wg.Wait()
      fmt.Println()
  }

  func main() {
      fizzBuzz(20)
  }

  // Output: 1 2 Fizz 4 Buzz Fizz 7 8 Fizz Buzz 11 Fizz 13 14 FizzBuzz 16 17 Fizz 19 Buzz

