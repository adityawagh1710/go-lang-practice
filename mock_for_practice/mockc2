D02. Fan-out / Fan-in Pipeline
--------------------------------------------------------------------------------
PROBLEM:
  Create a pipeline that:
    1. Generates numbers 1..n (source)
    2. Fans out to 3 workers that square each number
    3. Fans in (merges) all worker results into one channel

CODE:
  package main

  import (
      "fmt"
      "sync"
  )

  // Stage 1 — source
  func generate(nums ...int) <-chan int {
      out := make(chan int)
      go func() {
          for _, n := range nums {
              out <- n
          }
          close(out)
      }()
      return out
  }

  // Stage 2 — worker (square)
  func square(in <-chan int) <-chan int {
      out := make(chan int)
      go func() {
          for n := range in {
              out <- n * n
          }
          close(out)
      }()
      return out
  }

  // Stage 3 — fan-in (merge)
  func merge(cs ...<-chan int) <-chan int {
      var wg sync.WaitGroup
      merged := make(chan int)

      output := func(c <-chan int) {
          defer wg.Done()
          for v := range c {
              merged <- v
          }
      }

      wg.Add(len(cs))
      for _, c := range cs {
          go output(c)
      }

      go func() {
          wg.Wait()
          close(merged)
      }()
      return merged
  }

  func main() {
      in := generate(1, 2, 3, 4, 5, 6, 7, 8, 9)

      // Fan-out to 3 workers
      c1 := square(in)
      c2 := square(in)
      c3 := square(in)

      // Fan-in
      for result := range merge(c1, c2, c3) {
          fmt.Print(result, " ")
      }
      fmt.Println()
      // Output: squares of 1-9 in non-deterministic order
  }

PATTERN: Pipeline + Fan-out + Fan-in

