G03. Worker Pool Processing Jobs
--------------------------------------------------------------------------------
PROBLEM:
  Process a batch of jobs (simulate HTTP calls) using a fixed worker pool.
  Collect results and errors.

CODE:
  package main

  import (
      "fmt"
      "math/rand"
      "sync"
      "time"
  )

  type Job struct {
      ID int
  }

  type Result struct {
      JobID  int
      Output string
      Err    error
  }

  func process(job Job) Result {
      // Simulate variable processing time
      time.Sleep(time.Duration(rand.Intn(100)) * time.Millisecond)
      if job.ID%7 == 0 {
          return Result{JobID: job.ID, Err: fmt.Errorf("job %d failed", job.ID)}
      }
      return Result{JobID: job.ID, Output: fmt.Sprintf("job %d done", job.ID)}
  }

  func runWorkerPool(jobs []Job, numWorkers int) []Result {
      jobCh    := make(chan Job, len(jobs))
      resultCh := make(chan Result, len(jobs))

      // Fill job channel
      for _, job := range jobs {
          jobCh <- job
      }
      close(jobCh)

      // Spawn workers
      var wg sync.WaitGroup
      for i := 0; i < numWorkers; i++ {
          wg.Add(1)
          go func() {
              defer wg.Done()
              for job := range jobCh {
                  resultCh <- process(job)
              }
          }()
      }

      // Close result channel when all workers finish
      go func() {
          wg.Wait()
          close(resultCh)
      }()

      // Collect results
      var results []Result
      for r := range resultCh {
          results = append(results, r)
      }
      return results
  }

  func main() {
      jobs := make([]Job, 20)
      for i := range jobs {
          jobs[i] = Job{ID: i + 1}
      }

      results := runWorkerPool(jobs, 5)

      var errors, successes int
      for _, r := range results {
          if r.Err != nil {
              errors++
          } else {
              successes++
          }
      }
      fmt.Printf("Processed %d jobs: %d success, %d errors\n",
          len(results), successes, errors)
  }

PATTERN: Worker Pool
COMPLEXITY:
  Time:  O(n / numWorkers) — parallel execution
  Space: O(n) — buffered channels

