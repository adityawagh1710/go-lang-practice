B03. Find Middle of a Linked List
--------------------------------------------------------------------------------
PROBLEM:
  Return the middle node of a linked list.
  If even number of nodes, return the second middle.

APPROACH:
  Slow and fast pointers — when fast reaches end, slow is at middle.

CODE:
  package main

  import "fmt"

  type ListNode struct {
      Val  int
      Next *ListNode
  }

  func middleNode(head *ListNode) *ListNode {
      slow, fast := head, head

      for fast != nil && fast.Next != nil {
          slow = slow.Next
          fast = fast.Next.Next
      }
      return slow
  }

  func main() {
      // 1 -> 2 -> 3 -> 4 -> 5
      head := &ListNode{1, &ListNode{2, &ListNode{3,
          &ListNode{4, &ListNode{5, nil}}}}}
      fmt.Println(middleNode(head).Val) // 3

      // 1 -> 2 -> 3 -> 4
      head2 := &ListNode{1, &ListNode{2, &ListNode{3,
          &ListNode{4, nil}}}}
      fmt.Println(middleNode(head2).Val) // 3 (second middle)
  }

COMPLEXITY:
  Time:  O(n)
  Space: O(1)

