G02. Timeout with Select
--------------------------------------------------------------------------------
PROBLEM:
  Call a slow function. If it doesn't return within a timeout, cancel
  and return an error.

CODE:
  package main

  import (
      "context"
      "errors"
      "fmt"
      "time"
  )

  var ErrTimeout = errors.New("operation timed out")

  func slowOperation(ctx context.Context) (string, error) {
      result := make(chan string, 1)

      go func() {
          // Simulate slow work
          time.Sleep(2 * time.Second)
          result <- "done"
      }()

      select {
      case res := <-result:
          return res, nil
      case <-ctx.Done():
          return "", ErrTimeout
      }
  }

  func main() {
      // Timeout shorter than work — will time out
      ctx, cancel := context.WithTimeout(context.Background(), 1*time.Second)
      defer cancel()

      res, err := slowOperation(ctx)
      if err != nil {
          fmt.Println("Error:", err) // Error: operation timed out
      } else {
          fmt.Println("Result:", res)
      }

      // Timeout longer than work — will succeed
      ctx2, cancel2 := context.WithTimeout(context.Background(), 3*time.Second)
      defer cancel2()

      res2, err2 := slowOperation(ctx2)
      if err2 != nil {
          fmt.Println("Error:", err2)
      } else {
          fmt.Println("Result:", res2) // Result: done
      }
  }

PATTERN: Context timeout + select

NOTE:
  The result channel is buffered (cap=1) so the goroutine doesn't leak
  if we time out — it can still send and exit even if nobody receives.

