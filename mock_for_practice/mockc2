E03. Word Frequency Counter
--------------------------------------------------------------------------------
PROBLEM:
  Given a string of words, return the top k most frequent words,
  sorted by frequency (ties broken alphabetically).

CODE:
  package main

  import (
      "fmt"
      "sort"
      "strings"
  )

  func topKFrequent(words []string, k int) []string {
      freq := make(map[string]int)
      for _, w := range words {
          freq[w]++
      }

      unique := make([]string, 0, len(freq))
      for w := range freq {
          unique = append(unique, w)
      }

      sort.Slice(unique, func(i, j int) bool {
          if freq[unique[i]] != freq[unique[j]] {
              return freq[unique[i]] > freq[unique[j]] // higher freq first
          }
          return unique[i] < unique[j] // alphabetical tie-break
      })

      return unique[:k]
  }

  func main() {
      words := strings.Fields("the day is sunny the the the sunny is is")
      fmt.Println(topKFrequent(words, 4))
      // [the is sunny day]
  }

COMPLEXITY:
  Time:  O(n + m log m) — n words, m unique words
  Space: O(m)

