4. Two Sum Problem
--------------------------------------------------
Q: Find two numbers that add up to target

A:
func twoSum(nums []int, target int) []int {
    m := make(map[int]int)

    for i, num := range nums {
        if j, ok := m[target-num]; ok {
            return []int{j, i}
        }
        m[num] = i
    }

    return nil
}

