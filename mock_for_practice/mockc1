6. Fibonacci (Iterative)
--------------------------------------------------
Q: Generate nth Fibonacci number

A:
func fibonacci(n int) int {
    if n <= 1 {
        return n
    }

    a, b := 0, 1
    for i := 2; i <= n; i++ {
        a, b = b, a+b
    }

    return b
}

