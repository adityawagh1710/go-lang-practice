14. Check Anagram
--------------------------------------------------
Q: Check if two strings are anagrams

A:
func isAnagram(s1, s2 string) bool {
    if len(s1) != len(s2) {
        return false
    }

    count := make(map[rune]int)

    for _, ch := range s1 {
        count[ch]++
    }

    for _, ch := range s2 {
        count[ch]--
        if count[ch] < 0 {
            return false
        }
    }

    return true
}

