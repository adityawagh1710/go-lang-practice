3. Find Duplicate in Slice
--------------------------------------------------
Q: Find duplicates in integer slice

A:
func findDuplicates(nums []int) []int {
    seen := make(map[int]bool)
    duplicates := []int{}

    for _, num := range nums {
        if seen[num] {
            duplicates = append(duplicates, num)
        } else {
            seen[num] = true
        }
    }

    return duplicates
}

